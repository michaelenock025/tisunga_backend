# ── Core ────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://your-domain.com

# ── Database ─────────────────────────────────────────────────────────
# Railway / Render will inject this automatically if you attach their Postgres add-on
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/tisunga_db

# ── Cache ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_64_HEX_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_64_HEX_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── SMS — Africa's Talking ────────────────────────────────────────────
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=tisunga          # your AT username (sandbox for testing)
AT_SENDER_ID=TISUNGA

# ── Payments — pawaPay ───────────────────────────────────────────────
# Sign up at https://dashboard.pawapay.io  → API tokens
PAWAPAY_API_TOKEN=your_pawapay_bearer_token
PAWAPAY_BASE_URL=https://api.pawapay.io        # use https://api.sandbox.pawapay.io for testing
PAWAPAY_COUNTRY=MWI
PAWAPAY_CURRENCY=MWK

# ── Webhooks ─────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=CHANGE_ME_32_HEX_CHARS

# ── Push Notifications — Firebase ────────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── File Uploads — Cloudinary (optional) ─────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── CORS ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-frontend.com,https://your-admin.com
